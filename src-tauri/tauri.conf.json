{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "com.neruyomi.reader",
  "productName": "NeruYomi",
  "version": "0.48.0",

  "build": {
    "frontendDist": "../dist"
  },

  "app": {
    "windows": [
      {
        "title": "NeruYomi",
        "width": 1280,
        "height": 800,
        "minWidth": 600,
        "minHeight": 400,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },

  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}